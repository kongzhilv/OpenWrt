# ==========================================
# 0. 目标机型选择: CMCC RAX3000M eMMC 版
# ==========================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m-emmc=y
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_ALL_PROFILES=n

# ==========================================
# 1. 基础网页管理界面 (LuCI) 与中文支持
# ==========================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ==========================================
# 2. 核心插件包 (含冲突排除机制)
# ==========================================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-wechatpush=y
CONFIG_PACKAGE_luci-i18n-wechatpush-zh-cn=y
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_sing-box=y

# 指定安装老版 filebrowser，封杀 filebrowser-go 冲突
CONFIG_PACKAGE_filebrowser=y
CONFIG_PACKAGE_luci-app-filebrowser=y
# CONFIG_PACKAGE_luci-app-filebrowser-go is not set
# CONFIG_PACKAGE_luci-i18n-filebrowser-go-zh-cn is not set
# CONFIG_PACKAGE_filebrowser-go is not set

# ==========================================
# 3. Wi-Fi 基础组件与加密支持
# ==========================================
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wpad-openssl=y

# ==========================================
# 4. USB 核心与高速存储驱动 (U盘/移动硬盘)
# ==========================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y

# ==========================================
# 5. USB 网络共享与 5G/4G 上网卡驱动
# ==========================================
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y

# ==========================================
# 6. USB 有线网卡扩展驱动
# ==========================================
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y

# ==========================================
# 7. 系统底层实用工具箱
# ==========================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_autocore=y

# ==========================================
# 8. 底层系统与网络核心 (SSH, 拨号, 必备基础)
# ==========================================
# SSH终端与WinSCP文件传输必备
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_openssh-sftp-server=y
# 满血版DNS (OpenClash/AdGuardHome防冲突必备)
CONFIG_PACKAGE_dnsmasq_full=y
# CONFIG_PACKAGE_dnsmasq is not set
# 宽带拨号组件
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_luci-proto-ppp=y
# HTTPS 根证书 (防止部分软件无法联网下载规则)
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
